<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LSSD - BSSS Supervisory Toolset</title>
    <style>
        :root {
            --bg: #f0f0f0;
            --card-bg: #ffffff;
            --text: #1a1a1a;
            --text-muted: #666;
            --lssd-gold: #c5a059;
            --lssd-gold-light: #d4b47a;
            --lssd-green: #2d5a27;
            --lssd-green-dark: #1e3d1a;
            --border: #dddddd;
            --input-bg: #f8f8f8;
            --sticky-top: 20px;
            --row-zero: rgba(220, 50, 50, 0.10);
            --row-zero-border: rgba(220, 50, 50, 0.35);
            --row-low: rgba(220, 150, 20, 0.10);
            --row-low-border: rgba(220, 150, 20, 0.35);
            --row-no-text: #888;
            --bar-bg: rgba(0,0,0,0.08);
            --output-bg: #1a1a2e;
            --output-text: #4ade80;
        }

        [data-theme="dark"] {
            --bg: #111318;
            --card-bg: #1c1f26;
            --text: #e2e4ea;
            --text-muted: #8a8f9e;
            --lssd-green: #3d7a35;
            --lssd-green-dark: #2a5524;
            --border: #2d3140;
            --input-bg: #141720;
            --row-zero: rgba(220, 60, 60, 0.15);
            --row-zero-border: rgba(220, 60, 60, 0.4);
            --row-low: rgba(220, 160, 30, 0.12);
            --row-low-border: rgba(220, 160, 30, 0.38);
            --row-no-text: #555;
            --bar-bg: rgba(255,255,255,0.06);
            --output-bg: #0d1117;
            --output-text: #3ddc84;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 20px;
            transition: background 0.25s, color 0.25s;
            line-height: 1.45;
        }

        .container { max-width: 1400px; margin: auto; }

        /* HEADER */
        header {
            text-align: center;
            border-bottom: 3px solid var(--lssd-gold);
            margin-bottom: 10px;
            padding-bottom: 12px;
            position: relative;
        }
        header h1 { margin: 5px 0 2px; font-size: 1.3em; letter-spacing: 0.05em; }
        header p { margin: 0; font-size: 0.78em; color: var(--text-muted); letter-spacing: 0.08em; text-transform: uppercase; }

        .theme-switch {
            position: absolute;
            right: 0;
            top: 10px;
            cursor: pointer;
            background: var(--lssd-green);
            color: white;
            border: none;
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 0.78em;
            font-weight: bold;
            transition: background 0.2s;
        }
        .theme-switch:hover { background: var(--lssd-green-dark); }

        .warning {
            color: #e8574a;
            font-weight: bold;
            text-align: center;
            margin-bottom: 18px;
            text-transform: uppercase;
            font-size: 0.82em;
            background: rgba(220,50,50,0.06);
            border: 1px solid rgba(220,50,50,0.2);
            padding: 8px 12px;
            border-radius: 6px;
        }

        /* TABS */
        .tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 20px;
            border-bottom: 2px solid var(--border);
            overflow-x: auto;
        }
        .tab-btn {
            padding: 11px 18px;
            border: none;
            background: var(--card-bg);
            cursor: pointer;
            font-weight: bold;
            border-radius: 7px 7px 0 0;
            transition: background 0.15s, color 0.15s;
            color: var(--text-muted);
            white-space: nowrap;
            font-size: 0.85em;
            border: 1px solid var(--border);
            border-bottom: none;
        }
        .tab-btn:hover { background: var(--lssd-green); color: white; }
        .tab-btn.active { background: var(--lssd-green); color: white; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }

        /* LAYOUT */
        .grid { display: grid; grid-template-columns: 1fr 420px; gap: 28px; align-items: start; }

        .card {
            border: 1px solid var(--border);
            padding: 18px 20px;
            border-radius: 8px;
            background: var(--card-bg);
            margin-bottom: 18px;
            box-shadow: 0 1px 6px rgba(0,0,0,0.07);
        }
        .card h3 {
            margin-top: 0;
            color: var(--lssd-gold);
            border-bottom: 1px solid var(--border);
            padding-bottom: 9px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 1.05em;
        }
        .card h3 span { font-size: 0.8em; color: var(--text-muted); font-weight: normal; }

        /* FORM ELEMENTS */
        .input-group { margin-bottom: 14px; display: flex; flex-direction: column; }
        .input-group label { font-size: 0.78em; font-weight: bold; margin-bottom: 4px; color: var(--lssd-gold); text-transform: uppercase; letter-spacing: 0.05em; }
        input[type="text"], input[type="date"], select, textarea {
            padding: 9px 11px;
            background: var(--input-bg);
            color: var(--text);
            border: 1px solid var(--border);
            border-radius: 5px;
            font-family: inherit;
            font-size: 0.9em;
            transition: border-color 0.15s, background 0.25s;
        }
        input[type="text"]:focus, input[type="date"]:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--lssd-gold);
        }

        /* TOPIC ROWS */
        .topic-row {
            display: grid;
            grid-template-columns: 2.5fr 80px 80px 50px;
            gap: 10px;
            align-items: center;
            padding: 7px 8px;
            border-bottom: 1px solid var(--border);
            border-radius: 4px;
            transition: background 0.15s, border-color 0.15s;
        }
        .topic-row:last-of-type { border-bottom: none; }
        .topic-header { font-weight: bold; font-size: 0.72em; text-transform: uppercase; opacity: 0.6; padding: 4px 8px; }
        .topic-label { font-size: 0.88em; font-weight: 500; }
        .max-tag { font-size: 0.78em; color: var(--lssd-gold); font-weight: bold; margin-left: 4px; }
        .mandatory { color: #e8574a; font-weight: bold; margin-left: 3px; }

        /* COLOR CODING */
        .row-zero {
            background: var(--row-zero) !important;
            border-left: 3px solid var(--row-zero-border) !important;
            border-bottom-color: transparent !important;
            margin-left: -3px;
        }
        .row-low {
            background: var(--row-low) !important;
            border-left: 3px solid var(--row-low-border) !important;
            border-bottom-color: transparent !important;
            margin-left: -3px;
        }
        .row-observed { opacity: 1; }
        .row-no { opacity: 0.42; }

        /* SIDEBAR */
        .sidebar-sticky { position: sticky; top: var(--sticky-top); display: flex; flex-direction: column; gap: 18px; }

        .score-box {
            background: var(--lssd-green);
            color: white;
            padding: 22px 20px;
            border-radius: 8px;
            text-align: center;
        }
        .score-label { font-size: 0.75em; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.85; margin-bottom: 4px; }
        .score-val { font-size: 3.2em; font-weight: bold; color: white; line-height: 1; }
        .pass-status { font-weight: bold; margin-top: 10px; font-size: 1.05em; }

        /* CATEGORY BREAKDOWN BARS */
        .breakdown-card { padding: 14px 16px; }
        .breakdown-card h3 { font-size: 0.95em; margin-bottom: 10px; }
        .cat-bar-row { margin-bottom: 9px; }
        .cat-bar-label {
            display: flex;
            justify-content: space-between;
            font-size: 0.75em;
            margin-bottom: 3px;
            font-weight: 500;
        }
        .cat-bar-label span:first-child { color: var(--text); }
        .cat-bar-label span:last-child { color: var(--lssd-gold); font-weight: bold; }
        .cat-bar-track {
            height: 7px;
            background: var(--bar-bg);
            border-radius: 4px;
            overflow: hidden;
        }
        .cat-bar-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.3s ease, background 0.3s ease;
        }

        /* OUTPUT / BBCODE */
        textarea.comment-box {
            width: 100%;
            min-height: 80px;
            resize: vertical;
            margin-top: 8px;
            box-sizing: border-box;
        }
        .output-box {
            width: 100%;
            height: 380px;
            font-family: 'Courier New', monospace;
            font-size: 11px;
            white-space: pre;
            overflow: auto;
            margin-top: 10px;
            background: var(--output-bg);
            color: var(--output-text);
            border: 1px solid var(--border);
            border-radius: 5px;
            padding: 10px;
            resize: vertical;
        }

        /* BUTTONS */
        .btn {
            background: var(--lssd-gold);
            color: #1a1a1a;
            border: none;
            padding: 11px 14px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            width: 100%;
            transition: background 0.15s, transform 0.1s;
            font-size: 0.88em;
            letter-spacing: 0.03em;
        }
        .btn:hover { background: var(--lssd-gold-light); }
        .btn:active { transform: scale(0.99); }
        .btn-copy {
            background: #3a3f50;
            color: white;
            margin-top: 8px;
        }
        .btn-copy:hover { background: #4a5060; }

        [type="checkbox"] { transform: scale(1.3); cursor: pointer; accent-color: var(--lssd-green); }

        /* COPY TOAST */
        .copy-toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--lssd-green);
            color: white;
            padding: 10px 20px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 0.85em;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity 0.2s, transform 0.2s;
            pointer-events: none;
            z-index: 999;
        }
        .copy-toast.show { opacity: 1; transform: translateY(0); }

        /* RECOMMENDATION FIELD */
        .recommendation-card { border: 2px solid var(--lssd-gold) !important; }
        .recommendation-card h3 { color: var(--lssd-gold); }

        select.recommendation-select {
            font-weight: bold;
            font-size: 0.95em;
        }
        select.recommendation-select option[value="RECOMMENDED"] { color: #3ddc84; }
        select.recommendation-select option[value="RE-EVALUATION"] { color: #f5a623; }
        select.recommendation-select option[value="NOT_RECOMMENDED"] { color: #e8574a; }

        /* OOC SECTION */
        .ooc-card { border: 2px solid var(--lssd-green) !important; }
        .ooc-card h3 span { color: var(--lssd-gold); }

        /* RESPONSIVE */
        @media (max-width: 900px) {
            .grid { grid-template-columns: 1fr; }
            .sidebar-sticky { position: static; }
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <button class="theme-switch" onclick="toggleTheme()">🌙 Dark Mode</button>
        <img src="https://i.imgur.com/LEWTXbL.png" width="72" alt="LSSD">
        <h1>BSSS SUPERVISORY TOOLSET</h1>
        <p>Los Santos County Sheriff's Department — Basic Sergeant Supervisory School</p>
    </header>

    <div class="tabs">
        <button class="tab-btn active" onclick="openTab(event, 'obs')">Student Observation</button>
        <button class="tab-btn" onclick="openTab(event, 'edu')">Educational Patrol</button>
        <button class="tab-btn" onclick="openTab(event, 'eval')">Evaluation Patrol</button>
        <button class="tab-btn" onclick="openTab(event, 'final')">Final Evaluation</button>
    </div>

    <!-- ======================== TAB: OBSERVATION ======================== -->
    <div id="obs" class="tab-content active">
        <div class="grid">
            <div class="main-content">
                <div class="card">
                    <h3>Personnel & Grade</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="input-group"><label>Student Name</label><input type="text" id="obs_student"></div>
                        <div class="input-group"><label>Mentor Name</label><input type="text" id="obs_mentor"></div>
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="input-group"><label>Patrol Date</label><input type="date" id="obs_date"></div>
                        <div class="input-group"><label>Performance Grade</label>
                            <select id="obs_grade">
                                <option value="POSITIVE">POSITIVE</option>
                                <option value="NEGATIVE">NEGATIVE</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="card">
                    <h3>Narrative</h3>
                    <textarea id="obs_narrative" class="comment-box" style="height: 300px;" placeholder="Describe the observations here..."></textarea>
                </div>
            </div>
            <div class="sidebar-sticky">
                <div class="card">
                    <h3>Observation BBCode</h3>
                    <button class="btn" onclick="generateObsBBCode()">Generate BBCode</button>
                    <textarea id="obs_output" class="output-box" readonly placeholder="Output appears here..."></textarea>
                    <button class="btn btn-copy" onclick="copyText('obs_output')">Copy BBCode</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ======================== TAB: EDUCATIONAL PATROL ======================== -->
    <div id="edu" class="tab-content">
        <div class="grid">
            <div class="main-content">
                <div class="card">
                    <h3>Personnel Information</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="input-group"><label>Student Name</label><input type="text" id="edu_student_name"></div>
                        <div class="input-group"><label>Mentor Name</label><input type="text" id="edu_mentor_name"></div>
                    </div>
                    <div class="input-group"><label>Patrol Date</label><input type="date" id="edu_patrol_date"></div>
                </div>
                <div class="card"><h3>A. Delivered Practical and/or Theoretical Knowledge</h3><textarea id="edu_narrative_a" class="comment-box" style="height: 150px;" placeholder="Topics covered from the Student Checklist..."></textarea></div>
                <div class="card"><h3>B. Most Satisfactory Performance</h3><textarea id="edu_narrative_b" class="comment-box" style="height: 150px;" placeholder="Student's strongest areas..."></textarea></div>
                <div class="card"><h3>C. Least Satisfactory Performance</h3><textarea id="edu_narrative_c" class="comment-box" style="height: 150px;" placeholder="Areas needing improvement..."></textarea></div>
            </div>
            <div class="sidebar-sticky">
                <div class="card">
                    <h3>Educational BBCode</h3>
                    <button class="btn" onclick="generateEduBBCode()">Generate Edu BBCode</button>
                    <textarea id="edu_bbcode_output" class="output-box" readonly></textarea>
                    <button class="btn btn-copy" onclick="copyText('edu_bbcode_output')">Copy BBCode</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ======================== TAB: EVALUATION PATROL ======================== -->
    <div id="eval" class="tab-content">
        <div class="warning">⚠ Red asterisk (*) indicates mandatory task completion. ⚠</div>
        <div class="grid">
            <div class="main-content">
                <div class="card">
                    <h3>Personnel Information</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="input-group"><label>Student Name</label><input type="text" id="ev_student_name" oninput="calculateEval()"></div>
                        <div class="input-group"><label>Mentor Name</label><input type="text" id="ev_mentor_name" oninput="calculateEval()"></div>
                    </div>
                    <div class="input-group"><label>Patrol Date</label><input type="date" id="ev_patrol_date" onchange="calculateEval()"></div>
                </div>
                <div id="eval-categories-anchor"></div>
                <div class="card recommendation-card">
                    <h3>Mentor Recommendation</h3>
                    <div class="input-group">
                        <label>Recommendation</label>
                        <select id="ev_recommendation" class="recommendation-select">
                            <option value="RECOMMENDED">✅ Recommended for Progression</option>
                            <option value="RE-EVALUATION" selected>🔄 Recommended for Re-Evaluation</option>
                            <option value="NOT_RECOMMENDED">❌ Not Recommended</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>Recommendation Notes</label>
                        <textarea id="ev_recommendation_notes" class="comment-box" placeholder="Briefly justify your recommendation..."></textarea>
                    </div>
                </div>
                <div class="card"><h3>Report &amp; Narrative</h3><textarea id="ev_narrative" style="width:100%; height: 200px;" placeholder="Detailed rundown of the patrol..."></textarea></div>
            </div>
            <div class="sidebar-sticky">
                <div class="score-box">
                    <div class="score-label">Current Performance</div>
                    <div class="score-val" id="ev_final_score">0%</div>
                    <div class="pass-status" id="ev_pass_status">NEEDS EVALUATION</div>
                </div>
                <div class="card breakdown-card">
                    <h3>Category Breakdown</h3>
                    <div id="ev_breakdown"></div>
                </div>
                <div class="card">
                    <h3>Evaluation BBCode</h3>
                    <button class="btn" onclick="generateEvalBBCode()">Generate Eval BBCode</button>
                    <textarea id="ev_bbcode_output" class="output-box" readonly></textarea>
                    <button class="btn btn-copy" onclick="copyText('ev_bbcode_output')">Copy BBCode</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ======================== TAB: FINAL EVALUATION ======================== -->
    <div id="final" class="tab-content">
        <div class="warning">⚠ Check off N/O for unobserved topics to shift grading weight. ⚠</div>
        <div class="grid">
            <div class="main-content">
                <div class="card">
                    <h3>Personnel &amp; Session</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="input-group"><label>Student Name</label><input type="text" id="student_name" oninput="calculateFinal()"></div>
                        <div class="input-group"><label>Mentor Name</label><input type="text" id="mentor_name" oninput="calculateFinal()"></div>
                    </div>
                    <div class="input-group"><label>Patrol Date</label><input type="date" id="patrol_date" onchange="calculateFinal()"></div>
                </div>
                <div id="final-categories-anchor"></div>
                <div class="card ooc-card">
                    <h3>OOC Modifier <span>+5% Bonus Potential</span></h3>
                    <div id="ooc-rows"></div>
                    <div class="input-group" style="margin-top:14px;">
                        <label>OOC Performance Comments</label>
                        <textarea id="ooc_comment" class="comment-box" placeholder="Explain the OOC bonus..."></textarea>
                    </div>
                </div>
                <div class="card recommendation-card">
                    <h3>Mentor Recommendation</h3>
                    <div class="input-group">
                        <label>Recommendation</label>
                        <select id="fn_recommendation" class="recommendation-select">
                            <option value="RECOMMENDED">✅ Recommended for Promotion</option>
                            <option value="RE-EVALUATION" selected>🔄 Recommended for Re-Evaluation</option>
                            <option value="NOT_RECOMMENDED">❌ Not Recommended for Promotion</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>Recommendation Notes</label>
                        <textarea id="fn_recommendation_notes" class="comment-box" placeholder="Briefly justify your recommendation..."></textarea>
                    </div>
                </div>
                <div class="card"><h3>Overall Narrative</h3><textarea id="narrative" style="width:100%; height: 200px;" placeholder="Provide a detailed rundown of the patrol..."></textarea></div>
            </div>
            <div class="sidebar-sticky">
                <div class="score-box">
                    <div class="score-label">Final Performance Score</div>
                    <div class="score-val" id="final_score">0%</div>
                    <div class="pass-status" id="pass_status">NEEDS EVALUATION</div>
                </div>
                <div class="card breakdown-card">
                    <h3>Category Breakdown</h3>
                    <div id="fn_breakdown"></div>
                </div>
                <div class="card" style="margin-bottom: 0;">
                    <h3>BBCode Output</h3>
                    <button class="btn" onclick="generateFinalBBCode()">Generate Final BBCode</button>
                    <textarea id="bbcode_output" class="output-box" readonly></textarea>
                    <button class="btn btn-copy" onclick="copyText('bbcode_output')">Copy BBCode</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Copy Toast -->
<div class="copy-toast" id="copy-toast">✓ Copied to clipboard!</div>

<script>
    // =====================================================
    // DATA SCHEMAS
    // =====================================================

    const evalSchema = [
        { name: "Basics", weight: 0.15, topics: [
            {n: "Supervisor Presence", m: 3, r:true}, {n: "Resource Management", m: 3, r:true},
            {n: "Incident Management", m: 3, r:true}, {n: "Supervisor Requests", m: 2, r:true},
            {n: "Assigning Units", m: 2, r:true}, {n: "Briefs and Debriefs", m: 1, r:true},
            {n: "Understanding of the handle", m: 3, r:false}
        ]},
        { name: "Radio Procedure", weight: 0.10, topics: [
            {n: "Radio Communications (SCC & Local Tac)", m: 2, r:true},
            {n: "Radio Communications (Area Tac)", m: 2, r:true},
            {n: "External Radio Communications (Departmental)", m: 2, r:true}
        ]},
        { name: "Internal Relations", weight: 0.10, topics: [
