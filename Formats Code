            const fillW = pctVal !== null ? Math.max(2, pctVal) : 0;
            const color = getBarColor(pctVal);
            const label = pctVal !== null ? pctVal.toFixed(0) + "%" : "N/O";
            return `<div class="cat-bar-row">
                <div class="cat-bar-label">
                    <span>${c.name}</span>
                    <span style="color:${color}">${label}</span>
                </div>
                <div class="cat-bar-track">
