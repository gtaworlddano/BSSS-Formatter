    // =====================================================
    // SCORE COLOR HELPERS
    // =====================================================

    function getBarColor(pct) {
        if (pct === null) return '#555'; // N/O
        if (pct >= 90) return '#3ddc84';
        if (pct >= 75) return '#7bc67e';
        if (pct >= 50) return '#f5a623';
        return '#e8574a';
    }

    function colorTopicRow(rowEl, score, max, isNoObs) {
        rowEl.classList.remove('row-zero', 'row-low', 'row-no', 'row-observed');
        if (isNoObs) {
            rowEl.classList.add('row-no');
            return;
        }
        rowEl.classList.add('row-observed');
        if (score === 0) {
            rowEl.classList.add('row-zero');
        } else {
            const pct = score / max;
            if (pct < 0.5) rowEl.classList.add('row-low');
        }
    }

    // =====================================================
    // CALCULATE: EVALUATION
    // =====================================================

    function calculateEval() {
        let weightedSum = 0, totalObsWeight = 0;
        const catData = [];

        evalSchema.forEach((cat, cIdx) => {
            let catEarned = 0, catMax = 0, catObs = false;

            cat.topics.forEach((topic, tIdx) => {
                const noObsEl = document.querySelector(`.ev-no-obs[data-cat="${cIdx}"][data-topic="${tIdx}"]`);
                const baseEl = document.querySelector(`.ev-base[data-cat="${cIdx}"][data-topic="${tIdx}"]`);
                const modEl = document.querySelector(`.ev-mod[data-cat="${cIdx}"][data-topic="${tIdx}"]`);
                const rowEl = document.getElementById(`ev-row-${cIdx}-${tIdx}`);
                if (!noObsEl || !baseEl || !modEl) return;

                const isNoObs = noObsEl.checked;
                const base = parseInt(baseEl.value);
                const mod = parseInt(modEl.value);
                const score = Math.max(0, Math.min(topic.m, base + mod));

                if (rowEl) colorTopicRow(rowEl, score, topic.m, isNoObs);

                if (!isNoObs) {
                    catObs = true;
                    catEarned += score;
                    catMax += topic.m;
                }
            });

            const pct = (catObs && catMax > 0) ? (catEarned / catMax) * 100 : null;
            catData.push({ name: cat.name, pct, weight: cat.weight });

            if (catObs && catMax > 0) {
                weightedSum += (catEarned / catMax) * cat.weight;
                totalObsWeight += cat.weight;
            }
        });

        const finalPct = totalObsWeight > 0 ? (weightedSum / totalObsWeight) * 100 : 0;

        document.getElementById('ev_final_score').textContent = finalPct.toFixed(1) + "%";
        const st = document.getElementById('ev_pass_status');
        if (finalPct >= 90) { st.textContent = "SUPERIOR"; st.style.color = "#3ddc84"; }
        else if (finalPct >= 75) { st.textContent = "COMPETENT"; st.style.color = "#7bc67e"; }
        else { st.textContent = "NEEDS IMPROVEMENT"; st.style.color = "#ff8b8b"; }

        renderBreakdown('ev_breakdown', catData);
    }

    // =====================================================
    // CALCULATE: FINAL
    // =====================================================

    let fnCurrentBase = 0, fnCurrentOOC = 0, fnCurrentFinal = 0;

    function calculateFinal() {
        let weightedSum = 0, totalObsWeight = 0;
        const catData = [];

        finalSchema.forEach((cat, cIdx) => {
            let catEarned = 0, catMax = 0, catObs = false;

            cat.topics.forEach((topic, tIdx) => {
                const noObsEl = document.querySelector(`.fn-no-obs[data-cat="${cIdx}"][data-topic="${tIdx}"]`);
                const baseEl = document.querySelector(`.fn-base[data-cat="${cIdx}"][data-topic="${tIdx}"]`);
                const modEl = document.querySelector(`.fn-mod[data-cat="${cIdx}"][data-topic="${tIdx}"]`);
                const rowEl = document.getElementById(`fn-row-${cIdx}-${tIdx}`);
                if (!noObsEl || !baseEl || !modEl) return;

                const isNoObs = noObsEl.checked;
                const base = parseInt(baseEl.value);
                const mod = parseInt(modEl.value);
                const score = Math.max(0, Math.min(topic.m, base + mod));

                if (rowEl) colorTopicRow(rowEl, score, topic.m, isNoObs);

                if (!isNoObs) {
                    catObs = true;
                    catEarned += score;
                    catMax += topic.m;
                }
            });

            const pct = (catObs && catMax > 0) ? (catEarned / catMax) * 100 : null;
            catData.push({ name: cat.name, pct, weight: cat.weight });

            if (catObs && catMax > 0) {
                weightedSum += (catEarned / catMax) * cat.weight;
                totalObsWeight += cat.weight;
            }
        });

        let oocSum = 0;
        document.querySelectorAll('.ooc-score').forEach(s => oocSum += parseInt(s.value));
        fnCurrentOOC = (oocSum / (ooc_topics.length * 2)) * 5;
        fnCurrentBase = totalObsWeight > 0 ? (weightedSum / totalObsWeight) * 100 : 0;
        fnCurrentFinal = Math.min(100, fnCurrentBase + fnCurrentOOC);

        document.getElementById('final_score').textContent = fnCurrentFinal.toFixed(1) + "%";
        const st = document.getElementById('pass_status');
        if (fnCurrentFinal >= 75) { st.textContent = "COMPETENT / PASS"; st.style.color = "#8bff8b"; }
        else { st.textContent = "NEEDS IMPROVEMENT / FAIL"; st.style.color = "#ff8b8b"; }

        renderBreakdown('fn_breakdown', catData);
    }

