<script>

const categories = [
    ["Basics", 20, 7],
    ["Radio Procedure", 10, 3],
    ["Internal Relations", 10, 5],
    ["Management", 15, 4],
    ["Critical Incidents", 30, 10],
    ["Outside Agencies", 5, 2],
    ["Criminal Law", 10, 3]
];

const state = {};

function init() {
    const container = document.getElementById("scoreInputs");

    categories.forEach(cat => {
        const div = document.createElement("div");
        div.className = "scoreBox";

        div.innerHTML = `<b>${cat[0]} (${cat[1]}%)</b>`;

        state[cat[0]] = [];

        for (let i = 0; i < cat[2]; i++) {
            state[cat[0]].push({ base: 2, mod: 0 });

            div.innerHTML += `
            <div class="row">
                <div>
                    <label>Base</label>
                    <select onchange="setBase('${cat[0]}',${i},this.value)">
                        <option>0</option>
                        <option>1</option>
                        <option selected>2</option>
                    </select>
                </div>
                <div>
                    <label>Modifier</label>
                    <select onchange="setMod('${cat[0]}',${i},this.value)">
                        <option value="-1">-1</option>
                        <option value="0" selected>0</option>
                        <option value="1">+1</option>
                    </select>
                </div>
            </div>`;
        }

        container.appendChild(div);
    });

    updateScore();
}

function setBase(cat, i, val) {
    state[cat][i].base = parseInt(val);
    updateScore();
}

function setMod(cat, i, val) {
    state[cat][i].mod = parseInt(val);
    updateScore();
}

function updateScore() {
    let total = 0;

    categories.forEach(cat => {
        let catScore = 0;
        let max = cat[2] * 2;

        state[cat[0]].forEach(t => {
            catScore += (t.base + t.mod);
        });

        total += (catScore / max) * cat[1];
    });

    total = Math.max(0, Math.min(100, total + parseInt(document.getElementById("ooc").value)));

    document.getElementById("liveScore").innerText = total.toFixed(1);

    document.getElementById("status").innerText = total >= 75 ? "PASS" : "FAIL";
}

function generate() {

const student = document.getElementById("student").value;
const mentor = document.getElementById("mentor").value;
const date = document.getElementById("date").value;

const bb = `
[block=20,20,white,white][center]

[size=85][b]SERGEANT MENTOR EDUCATION PATROL REPORT[/b]
LOS SANTOS COUNTY SHERIFF'S DEPARTMENT

[/size][/center]
[hr][/hr]

[table]
[tr][td]Student[/td][td]Mentor[/td][td]Date[/td][/tr]
[tr][td]${student}[/td][td]${mentor}[/td][td]${date}[/td][/tr]
[/table]

[hr][/hr]

[b]FINAL SCORE:[/b] ${document.getElementById("liveScore").innerText}%
[b]RESULT:[/b] ${document.getElementById("status").innerText}

[hr][/hr]

[b]A. Delivered Knowledge[/b]
(see evaluation)

[b]B. Most Satisfactory Performance[/b]
(see evaluation)

[b]C. Least Satisfactory Performance[/b]
(see evaluation)

[/block]
`;

document.getElementById("output").value = bb;
}

function copyBB() {
navigator.clipboard.writeText(document.getElementById("output").value);
alert("Copied!");
}

init();

</script>

