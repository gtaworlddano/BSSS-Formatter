<h3>Scores</h3>

<div id="scoreInputs"></div>

<h3>OOC Modifier</h3>
<select id="ooc">
<option value="0">0%</option>
<option value="1">+1%</option>
<option value="2">+2%</option>
</select>

<button onclick="generate()">Generate BBCode</button>
<button onclick="copyBB()">Copy BBCode</button>

<div class="scoreBox">
<b>Live Score:</b> <span id="liveScore">0</span>%<br>
